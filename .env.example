# Configuration du micro-service Freemen Printer Proxy
# Compatible avec les imprimantes Brother QL et TD series

# ============================================
# CONFIGURATION SERVEUR
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# SÉCURITÉ API
# ============================================
# Clé API pour authentifier les requêtes du serveur cloud
# ⚠️ À CHANGER EN PRODUCTION ⚠️
API_KEY=dev-key-change-in-production

# ============================================
# CONFIGURATION IMPRIMANTE
# ============================================
# Adresse IP de l'imprimante Brother sur le réseau local
# Utilisez l'onglet Configuration du dashboard pour scanner et découvrir les imprimantes
PRINTER_IP=192.168.1.100

# Port de l'imprimante (9100 pour JetDirect, 631 pour IPP)
PRINTER_PORT=9100

# Type de protocole: 'jetdirect' ou 'ipp'
PRINTER_PROTOCOL=jetdirect

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_DIR=logs

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_POINTS=100
RATE_LIMIT_DURATION=60

# ============================================
# FORMATS D'ÉTIQUETTES
# ============================================
# Dimensions en millimètres
LABEL_SMALL_WIDTH=29
LABEL_SMALL_HEIGHT=29

LABEL_MEDIUM_WIDTH=62
LABEL_MEDIUM_HEIGHT=29

LABEL_LARGE_WIDTH=62
LABEL_LARGE_HEIGHT=62

# ============================================
# INTÉGRATION SERVEUR (OPTIONNEL)
# ============================================
# URL de votre serveur backend qui appellera ce micro-service
# Exemple: https://votre-api.example.com
CLOUD_SERVER_URL=

# Intervalle de heartbeat en secondes (0 pour désactiver)
HEARTBEAT_INTERVAL=30