{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Freemen Provisioner",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "http": {
        "all": true,
        "scope": ["https://api.cloudflare.com/*"]
      },
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": true
      },
      "fs": {
        "all": true,
        "scope": ["$APP/*", "$DOCUMENT/*", "$DESKTOP/*", "$DOWNLOAD/*"]
      },
      "path": {
        "all": true
      },
      "window": {
        "all": true
      },
      "clipboard": {
        "all": true
      },
      "os": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "© 2024 Freemen Solutions",
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.freemen.provisioner",
      "longDescription": "Freemen Provisioner is a desktop application for provisioning and configuring Freemen Printer Proxy devices with Cloudflare Tunnel integration.",
      "shortDescription": "Freemen Printer Proxy Provisioner",
      "resources": [],
      "targets": ["msi", "nsis"],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "webviewInstallMode": {
          "type": "downloadBootstrapper"
        },
        "wix": null,
        "nsis": {
          "displayLanguageSelector": false,
          "installerIcon": "icons/icon.ico",
          "installMode": "currentUser",
          "languages": ["English"],
          "license": null,
          "sidebarImage": null
        }
      }
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.cloudflare.com https://*.cloudflare.com https://downloads.raspberrypi.com; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Freemen Provisioner",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "center": true,
        "focus": true
      }
    ]
  }
}
