{
  "name": "freemen-printer-proxy",
  "version": "1.0.0",
  "description": "Freemen Printer Proxy - Expose local Brother QL/TD label printers via REST API for cloud integration",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "docker:build": "docker build -t freemen-printer-proxy .",
    "docker:run": "docker run -p 6500:6500 --env-file .env freemen-printer-proxy"
  },
  "keywords": [
    "brother",
    "printer",
    "label",
    "ql-710w",
    "raspberry-pi",
    "proxy",
    "api",
    "microservice",
    "freemen"
  ],
  "author": "Freemen Solutions",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "helmet": "^7.0.0",
    "rate-limiter-flexible": "^3.0.0",
    "winston": "^3.10.0",
    "ipp": "^2.0.0",
    "qrcode": "^1.5.3",
    "pdfkit": "^0.14.0",
    "axios": "^1.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Potarius/freemen-printer-proxy"
  },
  "homepage": "https://freemen.solutions",
  "bugs": {
    "url": "https://github.com/Potarius/freemen-printer-proxy/issues"
  }
}