{
  "name": "printer-proxy",
  "version": "1.0.0",
  "description": "Micro-service proxy pour imprimante Brother QL-710W - Expose l'imprimante locale via API REST pour serveur cloud",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "docker:build": "docker build -t printer-proxy .",
    "docker:run": "docker run -p 3000:3000 --env-file .env printer-proxy"
  },
  "keywords": [
    "brother",
    "printer",
    "ql-710w",
    "proxy",
    "api",
    "microservice"
  ],
  "author": "Nick Freeman",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "helmet": "^7.0.0",
    "rate-limiter-flexible": "^3.0.0",
    "winston": "^3.10.0",
    "ipp": "^2.0.0",
    "qrcode": "^1.5.3",
    "pdfkit": "^0.14.0",
    "axios": "^1.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/freemen-core/printer-proxy"
  }
}